# Copy these variable NAMES into your hosting provider (Vercel) and fill in
# the real values from your Supabase project. Do NOT put real keys in this
# file — real keys live only in .env.local (which is never uploaded).

NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
